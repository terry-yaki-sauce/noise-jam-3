    - rid: 8840176461771964517
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "Oh, hey there, Lucy! You\u2019re not looking so hot right now.\r\n"
        characterToShow: 5
        jumpIndex: -1
    - rid: 8840176461771964518
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "I\u2026 could be doing better right now.\r\n"
        characterToShow: 0
        jumpIndex: -1
    - rid: 8840176461771964519
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "Everything\u2019s been distorted, and I don\u2019t even know if I\u2019m
          in reality right now.\r\n"
        characterToShow: 0
        jumpIndex: -1
    - rid: 8840176461771964520
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "Here, let me help you. I\u2019ll guide you to the exit.\r\n"
        characterToShow: 5
        jumpIndex: -1
    - rid: 8840176461771964521
      type: {class: DialogueChoiceNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: Go with Gabe?
        characterToShow: 2
        jumpIndex: -1
        choices:
        - text: Yes
          jumpIndex: 5
        - text: No
          jumpIndex: 6
    - rid: 8840176461771964524
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: ' Alright, take me to the exit.'
        characterToShow: 0
        jumpIndex: 7
    - rid: 8840176461771964525
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "No, I\u2019ll find it myself"
        characterToShow: 0
        jumpIndex: 8
    - rid: 8840176461771964526
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: Perfect! Let's go
        characterToShow: 0
        jumpIndex: 99
    - rid: 8840176461771964527
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: Alright. Suit yourself.
        characterToShow: 0
        jumpIndex: -1
