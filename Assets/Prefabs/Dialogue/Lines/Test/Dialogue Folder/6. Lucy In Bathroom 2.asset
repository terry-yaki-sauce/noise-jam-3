    - rid: 8840176461771964501
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: The... realms?
        characterToShow: 0
        jumpIndex: -1
    - rid: 8840176461771964502
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: 'Watch your step as you walk through the different realities. Make
          them reveal the path forward with the tools at your disposal.

'
        characterToShow: 3
        jumpIndex: -1
    - rid: 8840176461771964503
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: You are not the chosen, but merely a puppet to the whims of Powers
          you could not control.
        characterToShow: 3
        jumpIndex: -1
    - rid: 8840176461771964504
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "You\u2019re not making any sense.\r\n"
        characterToShow: 0
        jumpIndex: -1
    - rid: 8840176461771964505
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: 'Good luck, I trust you will know who to trust.

'
        characterToShow: 3
        jumpIndex: -1
    - rid: 8840176461771964506
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: 'May your instincts guide you away from what you may initially seek.

'
        characterToShow: 3
        jumpIndex: -1
