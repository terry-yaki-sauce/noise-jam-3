    - rid: 8840176461771964536
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "\u2026 \u2026 ..cy! Lucy!\r\n"
        characterToShow: 6
        jumpIndex: -1
    - rid: 8840176461771964537
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "I\u2019m not even sure what happened- wait wait-\r\n"
        characterToShow: 6
        jumpIndex: -1
    - rid: 8840176461771964538
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "Guys! She\u2019s showing some signs of life.\r\n"
        characterToShow: 6
        jumpIndex: -1
    - rid: 8840176461771964539
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: 'Thank goodness! I was so worried we were going to lose you.

'
        characterToShow: 6
        jumpIndex: -1
    - rid: 8840176461771964540
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "What were we going to do without our fearless leader?? \r\n"
        characterToShow: 6
        jumpIndex: -1
    - rid: 8840176461771964541
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "\u2026\r\n"
        characterToShow: 6
        jumpIndex: -1
    - rid: 8840176461771964542
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "Well, I\u2019m glad you\u2019re safe. You probably feel terrible,
          but we\u2019ll be here to support you.\r\n"
        characterToShow: 6
        jumpIndex: -1
    - rid: 8840176461771964543
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: 'Ending 3:


          In the Arms of a Friend'
