    - rid: 8840176461771964487
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "Hey Lucy! I just wanted to see if you were still down to hang out
          at the club.\r\nThe other girls and I will be here partying.\r\nI know
          you\u2019re still reeling from that fight with your dad, but maybe this
          will cheer you up!\r\n"
        characterToShow: 6
        jumpIndex: -1
    - rid: 8840176461771964488
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "\u2026 "
        characterToShow: 6
        jumpIndex: -1
    - rid: 8840176461771964489
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "Oh? \r\n\r\n"
        characterToShow: 6
        jumpIndex: -1
    - rid: 8840176461771964490
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: Perfect! See you in a couple of hours!
