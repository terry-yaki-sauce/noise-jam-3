      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: "I\u2019d like to leave.\r\n"
        characterToShow: 0
        jumpIndex: -1
    - rid: 8840176461771964532
      type: {class: DialogueChoiceNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: 'Is that your final choice? Guided by a hand that does not belong to
          a friend?

'
        characterToShow: 4
        jumpIndex: -1
        choices:
        - text: Yes
          jumpIndex: 2
        - text: No
          jumpIndex: 3
    - rid: 8840176461771964533
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: 'If it is truly your choice, then step out to the light.

'
        characterToShow: 4
        jumpIndex: 99
    - rid: 8840176461771964534
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: 'Then I urge you to step back into the darkness that you call your
          own.

'
        characterToShow: 4
        jumpIndex: -1
    - rid: 8840176461771964535
      type: {class: DialogueNode, ns: Dialogue, asm: Assembly-CSharp}
      data:
        text: Do not fear the herald, for I will make sure he no longer hinders your
          progress.
        characterToShow: 4
