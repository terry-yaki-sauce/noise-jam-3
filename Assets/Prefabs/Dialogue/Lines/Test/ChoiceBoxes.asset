      data:
        text: This allows you to create responses to dialogue with different jump
          indices. These nodes do not use the jump index. Instead, They us a list
          of <b>Choice</b> objects to define string responses and jump indices.
        characterToShow: 2
        jumpIndex: -1
        voice: {fileID: 0}
        onStart:
